{
  "info": {
    "_postman_id": "e41a8e4a-8f2d-46af-9d4b-1f60db6c7f2c",
    "name": "RepoLens API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "Ingest Repo",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"github_url\": \"{{github_url}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/ingest",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "ingest"
          ]
        }
      }
    },
    {
      "name": "Job Status",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/jobs/{{job_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "jobs",
            "{{job_id}}"
          ]
        }
      }
    },
    {
      "name": "Get Summary",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/summary/{{repo_name}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "summary",
            "{{repo_name}}"
          ]
        }
      }
    },
    {
      "name": "Ask Question",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"repo_name\": \"{{repo_name}}\",\n  \"question\": \"{{question}}\",\n  \"top_k\": 8\n}"
        },
        "url": {
          "raw": "{{base_url}}/ask",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "ask"
          ]
        }
      }
    },
    {
      "name": "List Repos",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/repos",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "repos"
          ]
        }
      }
    },
    {
      "name": "Delete Repo",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/repos/{{repo_name}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "repos",
            "{{repo_name}}"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "github_url",
      "value": "https://github.com/tiangolo/fastapi.git"
    },
    {
      "key": "repo_name",
      "value": "fastapi"
    },
    {
      "key": "question",
      "value": "What are the core modules and what does the API app entrypoint do?"
    },
    {
      "key": "job_id",
      "value": ""
    }
  ]
}
